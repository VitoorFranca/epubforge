{
  "name": "@epubforge/core",
  "version": "0.1.0",
  "description": "Core library for converting web articles to EPUB files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/epub/assets && cp src/epub/assets/styles.css dist/epub/assets/styles.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
