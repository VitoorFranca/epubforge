{
  "name": "@epubforge/core",
  "version": "1.0.2",
  "description": "Core library for converting web articles to EPUB files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/epub/assets && cp src/epub/assets/styles.css dist/epub/assets/styles.css",
    "prepublishOnly": "npm run build && npm test",
    "postinstall": "playwright install chromium",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VitoorFranca/epubforge.git",
    "directory": "core"
  },
  "homepage": "https://github.com/VitoorFranca/epubforge#readme",
  "bugs": "https://github.com/VitoorFranca/epubforge/issues",
  "keywords": [
    "epub",
    "ebook",
    "kindle",
    "kobo",
    "converter",
    "readability",
    "playwright",
    "pandoc",
    "article",
    "web-scraping"
  ],
  "author": "Vitor França <franc.vitoor@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
